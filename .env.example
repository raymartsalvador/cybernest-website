# Copy to .env and fill in real values. Never commit .env.
#
# Only VITE_-prefixed vars are exposed to the browser. Do NOT put real
# secrets here — they will be inlined into the client bundle. Real secrets
# belong in Vercel env vars (no VITE_ prefix) and are accessed via
# serverless functions under /api/*.

# Backend base URL (public — safe to expose)
VITE_API_URL=https://your-backend.example.com/api

# Company slug used by the booking flow (public — safe to expose)
VITE_COMPANY_SLUG=your-company-slug

# Default timezone (public — safe to expose)
VITE_DEFAULT_TZ=Asia/Manila

# Feature flag for the booking modal. Set to "true" only after the backend
# auth model has been migrated off a client-exposed key (see /api/book
# serverless function). Default: disabled.
VITE_BOOKING_ENABLED=false

# DEPRECATED / TO BE REMOVED:
# VITE_X_API_KEY was inlined into the client bundle and is not a secret.
# Do not reintroduce. Move key-requiring calls behind /api/* serverless
# functions that read the key from a non-VITE_ env var in Vercel.
